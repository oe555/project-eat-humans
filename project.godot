; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project Eat Humans"
run/main_scene="uid://ujr45jajx4e7"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SignalBus="*res://Scripts/Core/signal_bus.gd"
GameState="*res://Scripts/Core/game_state.gd"
ShopManager="*res://Scripts/Core/shop_manager.gd"
AchievementManager="*res://Scripts/Core/achievement_manager.gd"
AudioPlayer="*res://Scripts/Core/audio_player.gd"
ConfigurationManager="*res://Scripts/Core/configuration_manager.gd"
Enums="*res://Scripts/Core/enums.gd"
LocalizationManager="*res://Scripts/Core/localization_manager.gd"
PlanetManager="*res://Scripts/Core/planet_manager.gd"
Randomizer="*res://Scripts/Core/randomizer.gd"
SaveManager="*res://Scripts/Core/save_manager.gd"
SceneManager="*res://Scripts/Core/scene_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[file_customization]

folder_colors={
"res://Assets/": "pink",
"res://Gemini/": "blue",
"res://Resources/": "yellow",
"res://Scenes/": "teal",
"res://Scripts/": "purple"
}

[global_group]

player="Used to track Player"

[input]

rotate_clockwise={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":68,"key_label":0,"unicode":100,"location":0,"echo":false,"script":null)
]
}
